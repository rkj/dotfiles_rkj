#!/usr/bin/env bash
start="$(( $(date '+%s') + $1))"
while [ $start -ge $(date +%s) ]; do
  time="$(( $start - $(date +%s) ))"
  if [[ "$(uname)" == "Darwin" ]]; then
    printf '%s\r' "$(date -u -r "$time" +%H:%M:%S)"
  else
    printf '%s\r' "$(date -u -d "@$time" +%H:%M:%S)"
  fi
  sleep 0.1
done

